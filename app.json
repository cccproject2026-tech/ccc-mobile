{
  "expo": {
    "name": "ccc-new-app",
    "slug": "ccc-new-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cccnewapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.georgejose.cccnewapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library so you can select a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library.",
        "UISupportsDocumentBrowser": true,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F3D5E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.georgejose.cccnewapp",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDUMMY-android-key-1234567890abcdef"
        }
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-screen.png",
          "resizeMode": "cover",
          "backgroundColor": "#0F3D5E"
        }
      ],

      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos so you can select a profile picture."
        }
      ],

      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],

      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0cbb679-9dcd-4414-8425-3dc78f7d6021"
      }
    }
  }
}